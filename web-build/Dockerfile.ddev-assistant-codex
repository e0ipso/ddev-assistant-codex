#ddev-generated
ARG BASE_IMAGE
FROM $BASE_IMAGE

# Pre-install Codex CLI to /usr/local/bin/codex so it is immediately
# available on PATH inside the web container, without needing a post-start
# hook to copy it into the home directory (which is a Docker named volume
# and would be masked by bind mounts under ~/.local/).
RUN npm install -g @openai/codex && \
    CODEX_BIN=$(which codex) && \
    if [ "$CODEX_BIN" != "/usr/local/bin/codex" ]; then \
        ln -sf "$CODEX_BIN" /usr/local/bin/codex; \
    fi
